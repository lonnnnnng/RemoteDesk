RD_HTTP_ADDR=:18081
RD_WS_PUBLIC_URL=ws://localhost:18081/ws
RD_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RD_DB_DSN=postgres://postgres:postgres@localhost:5432/remote_desk?sslmode=disable
RD_LOG_LEVEL=debug
RD_PROTOCOL_VERSION=1.0
RD_TURN_BIND_ADDR=0.0.0.0:3478
# 可选：显式指定 TURN 对外可达 IP（未设置时自动探测局域网私网 IP）
RD_TURN_PUBLIC_IP=
RD_TURN_REALM=remote.desk
RD_TURN_USERNAME=rd
RD_TURN_PASSWORD=rdpass
