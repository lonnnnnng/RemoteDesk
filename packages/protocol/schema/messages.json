{
  "protocol_version": "1.0",
  "messages": [
    {
      "type": "device.register.req",
      "required": ["device_id", "user_id", "platform", "client_version", "capabilities"],
      "constraints": [
        "payload.device_id must equal envelope.from.device_id"
      ],
      "payload": {
        "device_id": "string",
        "user_id": "string",
        "platform": "windows|macos|android",
        "client_version": "string",
        "device_name": "string",
        "capabilities": {
          "can_control": "boolean",
          "can_be_controlled": "boolean"
        }
      }
    },
    {
      "type": "device.register.rsp",
      "payload": {
        "result": "ok|error",
        "token": "string",
        "expires_in": "number",
        "server_time": "number",
        "device_name": "string",
        "error": "object|null"
      }
    },
    {
      "type": "presence.heartbeat.req",
      "required": ["token", "status"],
      "constraints": [
        "token must match the token issued during device.register.rsp"
      ],
      "payload": {
        "token": "string",
        "status": "online|busy",
        "active_session_id": "string|null"
      }
    },
    {
      "type": "presence.heartbeat.rsp",
      "payload": {
        "result": "ok",
        "next_interval_ms": "number",
        "device_status": "online|busy"
      }
    },
    {
      "type": "session.request.req",
      "required": ["target_device_id", "request_id", "auth_mode"],
      "constraints": [
        "caller must already be registered"
      ],
      "payload": {
        "target_device_id": "string",
        "request_id": "string",
        "auth_mode": "consent_required"
      }
    },
    {
      "type": "session.request.result.push",
      "payload": {
        "request_id": "string",
        "result": "approved|rejected|timeout",
        "reason": "string|null",
        "session_id": "string|null"
      }
    },
    {
      "type": "session.start.push",
      "payload": {
        "session_id": "string",
        "controller_device_id": "string",
        "agent_device_id": "string",
        "transport": {
          "mode": "webrtc",
          "signal_url": "string"
        },
        "webrtc": {
          "ice_servers": [
            {
              "urls": ["string"]
            }
          ]
        },
        "start_deadline_ms": "number"
      }
    },
    {
      "type": "session.end.req",
      "required": ["session_id", "reason"],
      "constraints": [
        "payload.session_id must equal envelope.session_id"
      ],
      "payload": {
        "session_id": "string",
        "reason": "user_end|network_lost|error"
      }
    },
    {
      "type": "session.end.push",
      "payload": {
        "session_id": "string",
        "reason": "user_end|peer_disconnected|timeout|server_terminate",
        "ended_at": "number"
      }
    },
    {
      "type": "input.mouse.move",
      "constraints": [
        "envelope.session_id is required"
      ],
      "payload": {
        "x": "number",
        "y": "number"
      }
    },
    {
      "type": "input.mouse.button",
      "constraints": [
        "envelope.session_id is required"
      ],
      "payload": {
        "button": "left|right|middle",
        "action": "down|up",
        "x": "number",
        "y": "number"
      }
    },
    {
      "type": "input.keyboard.key",
      "constraints": [
        "envelope.session_id is required"
      ],
      "payload": {
        "key_code": "string",
        "action": "down|up",
        "modifiers": ["string"]
      }
    },
    {
      "type": "input.wheel.scroll",
      "constraints": [
        "envelope.session_id is required"
      ],
      "payload": {
        "delta_x": "number",
        "delta_y": "number"
      }
    },
    {
      "type": "input.ack",
      "payload": {
        "accepted": "boolean",
        "echo_type": "string"
      }
    },
    {
      "type": "clipboard.text",
      "constraints": [
        "envelope.session_id is required",
        "only session participants may exchange clipboard text",
        "payload.text is UTF-8 text and must be bounded by relay size limits"
      ],
      "payload": {
        "clipboard_id": "string",
        "text": "string",
        "source_platform": "windows|macos|android",
        "created_at": "number"
      }
    },
    {
      "type": "clipboard.result",
      "constraints": [
        "envelope.session_id is required",
        "only session participants may report clipboard apply results",
        "payload.applied indicates whether the receiver wrote text to its system clipboard"
      ],
      "payload": {
        "clipboard_id": "string",
        "applied": "boolean",
        "chars": "number",
        "error_detail": "string",
        "created_at": "number"
      }
    },
    {
      "type": "file.transfer.start",
      "constraints": [
        "envelope.session_id is required",
        "only session participants may exchange files",
        "payload.sha256 is optional but must be a 64 character hex digest when present"
      ],
      "payload": {
        "file_id": "string",
        "name": "string",
        "mime": "string",
        "size": "number",
        "total_chunks": "number",
        "sha256": "string"
      }
    },
    {
      "type": "file.transfer.chunk",
      "constraints": [
        "envelope.session_id is required",
        "payload.file_id must match a preceding file.transfer.start",
        "data_base64 contains one bounded chunk of the file"
      ],
      "payload": {
        "file_id": "string",
        "chunk_index": "number",
        "total_chunks": "number",
        "data_base64": "string"
      }
    },
    {
      "type": "file.transfer.complete",
      "constraints": [
        "envelope.session_id is required",
        "sent after all file.transfer.chunk messages for the file_id",
        "payload.sha256 is optional but must match the received file bytes when present"
      ],
      "payload": {
        "file_id": "string",
        "name": "string",
        "mime": "string",
        "size": "number",
        "total_chunks": "number",
        "sha256": "string"
      }
    },
    {
      "type": "file.transfer.result",
      "constraints": [
        "envelope.session_id is required",
        "only session participants may report file receive results",
        "payload.applied indicates whether the receiver verified and saved the file"
      ],
      "payload": {
        "file_id": "string",
        "applied": "boolean",
        "name": "string",
        "bytes": "number",
        "sha256": "string",
        "location": "string",
        "error_detail": "string",
        "created_at": "number"
      }
    },
    {
      "type": "session.viewport.interaction",
      "constraints": [
        "envelope.session_id is required",
        "only session participants may exchange viewport interaction hints",
        "payload.phase must be start|update|end",
        "payload.interaction must be pinch|pan|fullscreen",
        "optional viewport/focus fields are normalized full-desktop coordinates in [0,1]"
      ],
      "payload": {
        "phase": "start|update|end",
        "interaction": "pinch|pan|fullscreen",
        "scale": "number",
        "viewport_x": "number",
        "viewport_y": "number",
        "viewport_width": "number",
        "viewport_height": "number",
        "focus_x": "number",
        "focus_y": "number",
        "created_at": "number"
      }
    },
    {
      "type": "screen.frame.push",
      "constraints": [
        "envelope.session_id is required",
        "only session participants may exchange legacy screen fallback frames",
        "payload.content_b64 must be bounded by relay size limits",
        "payload.mime_type must be image/png, image/jpeg, or image/webp",
        "optional source_rect fields describe the full-desktop normalized area encoded in this frame"
      ],
      "payload": {
        "frame_id": "string",
        "mime_type": "image/png|image/jpeg|image/webp",
        "content_b64": "string",
        "capture_ts": "number",
        "frame_width": "number",
        "frame_height": "number",
        "source_rect_x": "number",
        "source_rect_y": "number",
        "source_rect_width": "number",
        "source_rect_height": "number",
        "full_frame_width": "number",
        "full_frame_height": "number"
      }
    },
    {
      "type": "webrtc.offer",
      "constraints": [
        "envelope.session_id is required",
        "only session participants may exchange signaling"
      ],
      "payload": {
        "sdp_type": "offer",
        "sdp": "string"
      }
    },
    {
      "type": "webrtc.answer",
      "constraints": [
        "envelope.session_id is required",
        "only session participants may exchange signaling"
      ],
      "payload": {
        "sdp_type": "answer",
        "sdp": "string"
      }
    },
    {
      "type": "webrtc.ice_candidate",
      "constraints": [
        "envelope.session_id is required",
        "only session participants may exchange signaling"
      ],
      "payload": {
        "candidate": "string",
        "sdp_mid": "string",
        "sdp_mline_index": "number"
      }
    },
    {
      "type": "webrtc.restart_ice",
      "constraints": [
        "envelope.session_id is required",
        "only session participants may exchange signaling"
      ],
      "payload": {
        "reason": "string"
      }
    },
    {
      "type": "error.rsp",
      "payload": {
        "code": "number",
        "name": "string",
        "message": "string",
        "request_msg_id": "string",
        "retryable": "boolean",
        "device_id": "string"
      }
    }
  ]
}
